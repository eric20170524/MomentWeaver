MOMENTWEAVER_HOST=127.0.0.1
MOMENTWEAVER_PORT=8787
MOMENTWEAVER_RELOAD=0
MOMENTWEAVER_PYTHON=python3

# Nebula LLM SDK
NEBULA_API_KEY=
NEBULA_PROVIDER=openai
NEBULA_MODEL=gpt-4o-mini
NEBULA_BASE_URL=
NEBULA_SDK_PATH=/Users/lm/pyProj/hungry-for-knowledge/minigame_master/nebula_llm_sdk

# Smart Asset Kit
# MomentWeaver uses SAK for BGM. Course/video pipelines can reuse the same
# SAK MiniMax audio config for voiceover/TTS instead of system voices.
# Configure minimax_api_key and minimax_audio_model in:
#   $SMART_ASSET_KIT_PATH/.sak_config.json
SMART_ASSET_KIT_PATH=/Users/lm/pyProj/hungry-for-knowledge/minigame_master/smart-asset-kit
SAK_PYTHON=python3

# Companion course pipeline example:
# COURSE_TTS_PROVIDER=sak-minimax
